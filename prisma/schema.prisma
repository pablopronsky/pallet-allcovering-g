generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("SUPABASE_URL")
}

enum Role {
  ADMIN
  VENDEDOR
}

enum Sucursal {
  QUILMES
  LA_PLATA
  GONNET
}

enum MotivoBaja {
  MUESTRA
  ROTURA
  DONACION
  VENCIMIENTO
  OTRO
}

model User {
  id        String    @id @default(cuid())
  nombre    String
  email     String    @unique
  password  String
  rol       Role      @default(VENDEDOR)
  sucursal  Sucursal?
  ventas    Venta[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Producto {
  id        String    @id @default(cuid())
  nombre    String
  activo    Boolean   @default(true)
  ingresos  Ingreso[]
  ventas    Venta[]
  bajas     Baja[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Ingreso {
  id                 String    @id @default(cuid())
  productoId         String
  producto           Producto  @relation(fields: [productoId], references: [id])
  sucursal           Sucursal
  cantidadCajas      Int
  precioCostoPorCaja Float
  fecha              DateTime  @default(now())
  adminId            String
  notas              String?
  ventas             Venta[]   @relation("IngresoToVenta")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Venta {
  id                 String   @id @default(cuid())
  productoId         String
  producto           Producto @relation(fields: [productoId], references: [id])
  ingresoId          String
  ingreso            Ingreso  @relation("IngresoToVenta", fields: [ingresoId], references: [id])
  sucursal           Sucursal
  cantidadCajas      Int
  precioVentaPorCaja Float
  fecha              DateTime @default(now())
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  notas              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Baja {
  id            String     @id @default(cuid())
  productoId    String
  producto      Producto   @relation(fields: [productoId], references: [id])
  sucursal      Sucursal
  cantidadCajas Int
  motivo        MotivoBaja
  fecha         DateTime   @default(now())
  adminId       String
  notas         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}
